local function getPart(char, name)
    if not char then return nil end
    return char:FindFirstChild(name)
        or (name=="Torso" and char:FindFirstChild("UpperTorso"))
        or char:FindFirstChild("Head")
end

local function GetClosest(fov, part)
    local closest, best = nil, fov
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local tp = getPart(plr.Character, part)
                if tp then
                    local sp, on = Camera:WorldToViewportPoint(tp.Position)
                    if on then
                        local d = (Vector2.new(sp.X,sp.Y)-center).Magnitude
                        if d < best then closest=plr; best=d end
                    end
                end
            end
        end
    end
    return closest
end

local function w2s(pos)
    local sp, on = Camera:WorldToViewportPoint(pos)
    return Vector2.new(sp.X,sp.Y), on, sp.Z
end

local function getCharBounds(char)
    local minX,minY,minZ = math.huge,math.huge,math.huge
    local maxX,maxY,maxZ = -math.huge,-math.huge,-math.huge
    local found = false
    for _, p in ipairs(char:GetChildren()) do
        if p:IsA("BasePart") then
            found=true
            local pos,s = p.Position,p.Size
            minX=math.min(minX,pos.X-s.X/2) minY=math.min(minY,pos.Y-s.Y/2) minZ=math.min(minZ,pos.Z-s.Z/2)
            maxX=math.max(maxX,pos.X+s.X/2) maxY=math.max(maxY,pos.Y+s.Y/2) maxZ=math.max(maxZ,pos.Z+s.Z/2)
        end
    end
    if not found then return nil end
    return Vector3.new(minX,minY,minZ), Vector3.new(maxX,maxY,maxZ)
end

local function matchesBind(inp, bind)
    if not bind then return false end
    if bind.type=="mouse" then return inp.UserInputType==bind.value end
    if bind.type=="key" then
        if bind.value==Enum.KeyCode.Unknown then return false end
        return inp.UserInputType==Enum.UserInputType.Keyboard and inp.KeyCode==bind.value
    end
    return false
end


local _aimState = false
local _aimMode  = "Hold"
local _aimBindObj = nil

local function isAimBindPressed(inp)
    if not _aimBindObj then return inp.UserInputType==Enum.UserInputType.MouseButton2 end
    local bind = _aimBindObj.Value
    if not bind then return inp.UserInputType==Enum.UserInputType.MouseButton2 end
    if bind.type=="mouse" then return inp.UserInputType==bind.value end
    if bind.type=="key"   then
        return inp.UserInputType==Enum.UserInputType.Keyboard and inp.KeyCode==bind.value
    end
    return false
end

RunService.RenderStepped:Connect(function()
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    AimbotCircle.Position=center; AimbotCircle.Radius=AimbotSettings.FOV
    AimbotCircle.Color=AimbotSettings.FOVColor
    AimbotCircle.Visible=AimbotSettings.ShowFOV and AimbotSettings.Enabled and not _hidden

    if not (AimbotSettings.Enabled and _aimState) then AimbotSettings.StickyTarget=nil; return end
    local target
    if AimbotSettings.Sticky and AimbotSettings.StickyTarget then
        local sc=AimbotSettings.StickyTarget
        local hum=sc.Character and sc.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health>0 then target=sc else AimbotSettings.StickyTarget=nil end
    end
    if not target then
        target=GetClosest(AimbotSettings.FOV, AimbotSettings.TargetPart)
        if AimbotSettings.Sticky and target then AimbotSettings.StickyTarget=target end
    end
    if not (target and target.Character) then return end
    local tp=getPart(target.Character, AimbotSettings.TargetPart)
    if tp then Camera.CFrame=Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position,tp.Position),AimbotSettings.Smoothness) end
end)

UserInputService.InputBegan:Connect(function(inp, proc)
    if proc or not AimbotSettings.Enabled then return end
    if isAimBindPressed(inp) then
        if _aimMode=="Hold" then _aimState=true
        else _aimState=not _aimState; if not _aimState then AimbotSettings.StickyTarget=nil end end
    end
end)
UserInputService.InputEnded:Connect(function(inp)
    if _aimMode=="Hold" and isAimBindPressed(inp) then
        _aimState=false; AimbotSettings.StickyTarget=nil
    end
end)


local espFolder = Instance.new("Folder"); espFolder.Name="KraviXESP"; espFolder.Parent=workspace
local playerESP = {}

local skeletonBones = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
    {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
    {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
    {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
    {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
}

local function newLine(thick, zi)
    local l=Drawing.new("Line"); l.Thickness=thick or 1; l.Color=Color3.new(1,1,1)
    l.Transparency=1; l.ZIndex=zi or 1; l.Visible=false; return l
end
local function newText(sz, zi)
    local t=Drawing.new("Text"); t.Size=sz or 13; t.Color=Color3.new(1,1,1)
    t.Outline=true; t.ZIndex=zi or 2; t.Visible=false; return t
end

local function createESP(plr)
    if plr==LocalPlayer or playerESP[plr] then return end
    local d = {
        top=newLine(1,3), bottom=newLine(1,3), left=newLine(1,3), right=newLine(1,3),
        name=newText(13,4), distance=newText(11,4),
        tracer=newLine(1,1),
        skeleton={},
    }
    for i=1,#skeletonBones do d.skeleton[i]=newLine(1,2) end
    playerESP[plr]=d
end

local function removeESP(plr)
    local d=playerESP[plr]; if not d then return end
    for _, k in ipairs({"top","bottom","left","right","name","distance","tracer"}) do
        pcall(function() d[k]:Remove() end)
    end
    for _, l in ipairs(d.skeleton) do pcall(function() l:Remove() end) end
    playerESP[plr]=nil
end

local function hideESP(d)
    for _, k in ipairs({"top","bottom","left","right","name","distance","tracer"}) do d[k].Visible=false end
    for _, l in ipairs(d.skeleton) do l.Visible=false end
end

local function updateESP(plr, d)
    local char=plr.Character
    if not char then hideESP(d); return end
    local hrp=char:FindFirstChild("HumanoidRootPart")
    local hum=char:FindFirstChild("Humanoid")
    if not hrp or not hum or hum.Health<=0 then hideESP(d); return end

    local minB,maxB=getCharBounds(char)
    if not minB then hideESP(d); return end

    local topC=Vector3.new((minB.X+maxB.X)/2,maxB.Y,(minB.Z+maxB.Z)/2)
    local botC=Vector3.new((minB.X+maxB.X)/2,minB.Y,(minB.Z+maxB.Z)/2)
    local sTop,onTop,dTop=w2s(topC)
    local sBot=w2s(botC)
    if not onTop or dTop<0 then hideESP(d); return end

    local height=math.abs(sTop.Y-sBot.Y)
    local width=height*0.6
    local L,R,T,B=sTop.X-width/2,sTop.X+width/2,sTop.Y,sBot.Y
    local dist=math.floor((hrp.Position-Camera.CFrame.Position).Magnitude)

    local role = getRole(plr)
    local roleColor = ROLE_COLORS[role] or ROLE_COLORS.Innocent
    local function getColor(custom) return ESPSettings.UseRoleColor and roleColor or custom end

    if ESPSettings.Box then
        d.top.From=Vector2.new(L,T);    d.top.To=Vector2.new(R,T)
        d.bottom.From=Vector2.new(L,B); d.bottom.To=Vector2.new(R,B)
        d.left.From=Vector2.new(L,T);   d.left.To=Vector2.new(L,B)
        d.right.From=Vector2.new(R,T);  d.right.To=Vector2.new(R,B)
        local bc = getColor(ESPSettings.BoxColor)
        for _, k in ipairs({"top","bottom","left","right"}) do
            d[k].Color=bc; d[k].Transparency=1; d[k].Visible=true
        end
    else
        for _, k in ipairs({"top","bottom","left","right"}) do d[k].Visible=false end
    end

    if ESPSettings.Names then
        d.name.Text=plr.Name.." ["..role.."]"
        d.name.Color=getColor(ESPSettings.NameColor)
        d.name.Position=Vector2.new(sTop.X,T-16); d.name.Center=true; d.name.Visible=true
    else d.name.Visible=false end

    if ESPSettings.Distance then
        d.distance.Text=dist.."m"; d.distance.Color=getColor(ESPSettings.DistanceColor)
        d.distance.Position=Vector2.new(sTop.X,B+2); d.distance.Center=true; d.distance.Visible=true
    else d.distance.Visible=false end

    if ESPSettings.Tracers then
        local vp = Camera.ViewportSize
        local origin = ESPSettings.TracerOrigin=="Top"
            and Vector2.new(vp.X/2, 0) or Vector2.new(vp.X/2, vp.Y)
        local target2d = ESPSettings.TracerOrigin=="Top"
            and Vector2.new(sTop.X,T) or Vector2.new(sTop.X,B)
        d.tracer.From=origin; d.tracer.To=target2d
        d.tracer.Color=getColor(ESPSettings.TracerColor); d.tracer.Transparency=1; d.tracer.Visible=true
    else d.tracer.Visible=false end

    if ESPSettings.Skeleton then
        local sc = getColor(ESPSettings.SkeletonColor)
        for i,bone in ipairs(skeletonBones) do
            local p0=char:FindFirstChild(bone[1]); local p1=char:FindFirstChild(bone[2])
            if p0 and p1 then
                local s0,on0=w2s(p0.Position); local s1,on1=w2s(p1.Position)
                if on0 and on1 then
                    d.skeleton[i].From=s0; d.skeleton[i].To=s1
                    d.skeleton[i].Color=sc; d.skeleton[i].Transparency=1; d.skeleton[i].Visible=true
                else d.skeleton[i].Visible=false end
            else d.skeleton[i].Visible=false end
        end
    else for _, l in ipairs(d.skeleton) do l.Visible=false end end
end

