local _autoGrabGunEnabled = false
local _gunEspEnabled = false
local _gunDrawings = {}
local _gunEspColor = Color3.fromRGB(255,255,255)

local function updateGunEsp()
    local gun = workspace:FindFirstChild("GunDrop", true)
    if not gun or not _gunEspEnabled or _hidden then
        if _gunDrawings.label then _gunDrawings.label.Visible = false end
        if _gunDrawings.dot   then _gunDrawings.dot.Visible   = false end
        return
    end
    local gunPart = gun:IsA("BasePart") and gun or gun:FindFirstChildWhichIsA("BasePart",true)
    if not gunPart then return end
    local sp, on, depth = w2s(gunPart.Position + Vector3.new(0,1.5,0))
    if not on or depth < 0 then
        if _gunDrawings.label then _gunDrawings.label.Visible = false end
        if _gunDrawings.dot   then _gunDrawings.dot.Visible   = false end
        return
    end
    local dist = math.floor((gunPart.Position - Camera.CFrame.Position).Magnitude)
    if not _gunDrawings.label then
        _gunDrawings.label = Drawing.new("Text")
        _gunDrawings.label.Size = 13; _gunDrawings.label.Outline = true
        _gunDrawings.label.ZIndex = 4; _gunDrawings.label.Center = true
    end
    if not _gunDrawings.dot then
        _gunDrawings.dot = Drawing.new("Circle")
        _gunDrawings.dot.Thickness = 2; _gunDrawings.dot.NumSides = 12
        _gunDrawings.dot.Filled = true; _gunDrawings.dot.Radius = 5; _gunDrawings.dot.ZIndex = 4
    end
    _gunDrawings.label.Text = "Gun Drop ["..dist.."m]"
    _gunDrawings.label.Color = _gunEspColor
    _gunDrawings.label.Position = Vector2.new(sp.X, sp.Y - 16)
    _gunDrawings.label.Visible = true
    _gunDrawings.dot.Color = _gunEspColor
    _gunDrawings.dot.Position = Vector2.new(sp.X, sp.Y)
    _gunDrawings.dot.Visible = true
end

RunService.RenderStepped:Connect(function()
    if _gunEspEnabled and not _hidden then updateGunEsp()
    else
        if _gunDrawings.label then _gunDrawings.label.Visible = false end
        if _gunDrawings.dot   then _gunDrawings.dot.Visible   = false end
    end
end)

local function grabGun()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        if Window then Window.Notify("Gun","No character",3) end
        return false
    end
    local drop = workspace:FindFirstChild("GunDrop", true)
    if not drop then
        if Window then Window.Notify("Gun","No GunDrop found",3) end
        return false
    end
    if firetouchinterest then
        firetouchinterest(hrp, drop, 0)
        firetouchinterest(hrp, drop, 1)
    else
        drop.CFrame = hrp.CFrame
    end
    if Window then Window.Notify("Gun","Gun grabbed!",2) end
    return true
end

local function startAutoGrabGun()
    task.spawn(function()
        while _autoGrabGunEnabled do
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local bp = LocalPlayer:FindFirstChild("Backpack")
            local hasGun = (char and (char:FindFirstChild("Gun") or char:FindFirstChild("Sheriff Gun")))
                        or (bp  and (bp:FindFirstChild("Gun")  or bp:FindFirstChild("Sheriff Gun")))
            if not hasGun and hrp then
                local drop = workspace:FindFirstChild("GunDrop", true)
                if drop then
                    if firetouchinterest then firetouchinterest(hrp,drop,0); firetouchinterest(hrp,drop,1)
                    else drop.CFrame = hrp.CFrame end
                end
            end
            task.wait(0.1)
        end
    end)
end


local _invisEnabled = false
local _invisParts = {}
local _invisHumRef = nil
local _invisHRPRef = nil
local _invisConn = nil

local function collectInvisParts(char)
    _invisParts = {}
    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") and p.Transparency == 0 then
            table.insert(_invisParts, p)
        end
    end
end

local function setInvisible(state)
    _invisEnabled = state
    local char = LocalPlayer.Character
    if not char then return end
    _invisHumRef = char:FindFirstChildOfClass("Humanoid")
    _invisHRPRef = char:FindFirstChild("HumanoidRootPart")
    if state then
        collectInvisParts(char)
        for _, p in ipairs(_invisParts) do p.Transparency = 0.5 end
        if _invisConn then _invisConn:Disconnect() end
        _invisConn = RunService.Heartbeat:Connect(function()
            if not _invisEnabled then return end
            local hum = _invisHumRef
            local hrp = _invisHRPRef
            if not hum or not hrp then return end
            local savedCF = hrp.CFrame
            local savedOffset = hum.CameraOffset
            local dist = math.random(500000, 1000000)
            local below = savedCF * CFrame.new(0, -dist, 0)
            hrp.CFrame = below
            hum.CameraOffset = (below:ToObjectSpace(CFrame.new(savedCF.Position))).Position
            RunService.RenderStepped:Wait()
            hrp.CFrame = savedCF
            hum.CameraOffset = savedOffset
        end)
    else
        if _invisConn then _invisConn:Disconnect(); _invisConn = nil end
        for _, p in ipairs(_invisParts) do
            if p and p.Parent then p.Transparency = 0 end
        end
        _invisParts = {}
    end
end

LocalPlayer.CharacterAdded:Connect(function()
    if _invisEnabled then
        _invisEnabled = false
        if _invisConn then _invisConn:Disconnect(); _invisConn = nil end
        _invisParts = {}
    end
end)


