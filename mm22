UserInputService.InputBegan:Connect(function(inp, proc)
    if proc then return end

    
    if _invisBindObj and matchesBind(inp, _invisBindObj.Value) then
        setInvisible(not _invisEnabled)
    end

   
    if _shootBindObj and matchesBind(inp, _shootBindObj.Value) then
        shootMurderer()
    end

    
    if SpeedSettings.Enabled and _speedBindObj and matchesBind(inp, _speedBindObj.Value) then
        SpeedSettings.KeybindActive = not SpeedSettings.KeybindActive
        if not SpeedSettings.KeybindActive then
            local char=LocalPlayer.Character
            local hum=char and char:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed=16 end
        end
    end

    
    if JumpSettings.Enabled and _jumpBindObj and matchesBind(inp, _jumpBindObj.Value) then
        JumpSettings.KeybindActive = not JumpSettings.KeybindActive
        if not JumpSettings.KeybindActive then
            local char=LocalPlayer.Character
            local hum=char and char:FindFirstChildOfClass("Humanoid")
            if hum then hum.UseJumpPower=true; hum.JumpPower=50 end
        end
    end

    
    if FlySettings.Enabled and _flyBindObj and matchesBind(inp, _flyBindObj.Value) then
        FlySettings.Toggled = not FlySettings.Toggled
        if FlySettings.Toggled then startFly() else stopFly() end
    end

    
    if inp.UserInputType == Enum.UserInputType.Keyboard and _menuBindObj then
        local bind = _menuBindObj.Value
        if bind and bind.type=="key" and bind.value~=Enum.KeyCode.Unknown and inp.KeyCode==bind.value then
            Window.ToggleWindow()
        end
    end

    
    if _hideBindObj and matchesBind(inp, _hideBindObj.Value) then
        _hidden = not _hidden
        if _hidden then
            AimbotCircle.Visible=false
            for _, d in pairs(playerESP) do hideESP(d) end
        end
    end

    
    if _unloadBindObj and matchesBind(inp, _unloadBindObj.Value) then
        AimbotSettings.Enabled=false; _aimState=false; AimbotSettings.StickyTarget=nil
        SpeedSettings.Enabled=false; SpeedSettings.KeybindActive=false
        JumpSettings.Enabled=false;  JumpSettings.KeybindActive=false
        FlySettings.Enabled=false; FlySettings.Toggled=false; stopFly()
        _noclipEnabled=false; _autoGrabGunEnabled=false
        _gunEspEnabled=false; _touchFlingEnabled=false; _hidden=false
        _silentAimMurderer=false
        if _antiCollisionConn then _antiCollisionConn:Disconnect(); _antiCollisionConn=nil end
        if _invisEnabled then setInvisible(false) end
        toggleAntiFling(false)
        local char=LocalPlayer.Character
        local hum=char and char:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed=16; hum.JumpPower=50; hum.PlatformStand=false end
        if char then for _, p in ipairs(char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=true end end end
        ESPSettings.Enabled=false
        for plr, d in pairs(playerESP) do
            for _, k in ipairs({"top","bottom","left","right","name","distance","tracer"}) do
                pcall(function() d[k]:Remove() end)
            end
            for _, l in ipairs(d.skeleton) do pcall(function() l:Remove() end) end
            playerESP[plr]=nil
        end
        playerESP={}
        if _gunDrawings.label then pcall(function() _gunDrawings.label:Remove() end) end
        if _gunDrawings.dot   then pcall(function() _gunDrawings.dot:Remove()   end) end
        _gunDrawings={}
        pcall(function() if espFolder and espFolder.Parent then espFolder:Destroy() end end)
        AimbotCircle.Visible=false
        task.wait(0.1)
        if Window._ScreenGui and Window._ScreenGui.Parent then
            pcall(function() Window._ScreenGui:Destroy() end)
        end
    end
end)
