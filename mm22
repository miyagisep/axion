local _flyConn = nil
local _flyKeys = {w=false,s=false,a=false,d=false,space=false,shift=false}

local function startFly()
    if _flyConn then return end
    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if hum then hum.PlatformStand=true end
    _flyConn = RunService.Heartbeat:Connect(function(dt)
        if not FlySettings.Enabled then return end
        local c = LocalPlayer.Character; if not c then return end
        local hrp = c:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        local mv = Vector3.new(0,0,0); local spd = FlySettings.Speed
        if _flyKeys.w     then mv = mv + Camera.CFrame.LookVector  * spd end
        if _flyKeys.s     then mv = mv - Camera.CFrame.LookVector  * spd end
        if _flyKeys.a     then mv = mv - Camera.CFrame.RightVector * spd end
        if _flyKeys.d     then mv = mv + Camera.CFrame.RightVector * spd end
        if _flyKeys.space then mv = mv + Vector3.new(0,spd,0) end
        if _flyKeys.shift then mv = mv - Vector3.new(0,spd,0) end
        if mv.Magnitude > 0 then hrp.CFrame = hrp.CFrame + mv * dt end
        pcall(function() hrp.Velocity = Vector3.zero end)
    end)
end

local function stopFly()
    if _flyConn then _flyConn:Disconnect(); _flyConn=nil end
    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if hum then hum.PlatformStand=false end
end

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    if SpeedSettings.Enabled and SpeedSettings.KeybindActive then
        hum.WalkSpeed = SpeedSettings.Value
    end

    if JumpSettings.Enabled and JumpSettings.KeybindActive then
        hum.UseJumpPower = true
        hum.JumpPower = JumpSettings.Value
    end
end)

UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    local k = inp.KeyCode
    if k==Enum.KeyCode.W         then _flyKeys.w=true end
    if k==Enum.KeyCode.S         then _flyKeys.s=true end
    if k==Enum.KeyCode.A         then _flyKeys.a=true end
    if k==Enum.KeyCode.D         then _flyKeys.d=true end
    if k==Enum.KeyCode.Space     then _flyKeys.space=true end
    if k==Enum.KeyCode.LeftShift then _flyKeys.shift=true end
end)
UserInputService.InputEnded:Connect(function(inp)
    local k = inp.KeyCode
    if k==Enum.KeyCode.W         then _flyKeys.w=false end
    if k==Enum.KeyCode.S         then _flyKeys.s=false end
    if k==Enum.KeyCode.A         then _flyKeys.a=false end
    if k==Enum.KeyCode.D         then _flyKeys.d=false end
    if k==Enum.KeyCode.Space     then _flyKeys.space=false end
    if k==Enum.KeyCode.LeftShift then _flyKeys.shift=false end
end)


local function getMurderer()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character then
            local bp = v:FindFirstChild("Backpack")
            if v.Character:FindFirstChild("Knife") or (bp and bp:FindFirstChild("Knife")) then return v end
        end
    end
end

local function getSheriff()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character then
            local bp = v:FindFirstChild("Backpack")
            if v.Character:FindFirstChild("Gun") or v.Character:FindFirstChild("Sheriff Gun")
            or (bp and (bp:FindFirstChild("Gun") or bp:FindFirstChild("Sheriff Gun"))) then
                return v
            end
        end
    end
end

local function getNearestPlayer()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local best, found = math.huge, nil
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local d = (hrp.Position - v.Character.HumanoidRootPart.Position).Magnitude
            if d < best then best=d; found=v end
        end
    end
    return found
end

local function getPlayerNames()
    local names = {}
    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= LocalPlayer then table.insert(names, v.Name) end
    end
    return names
end


local _shootOffset = 2.8

local function getPredictedPosition(target)
    if not target or not target.Character then return nil end
    local hrp = target.Character:FindFirstChild("HumanoidRootPart")
        or target.Character:FindFirstChild("UpperTorso")
    if not hrp then return nil end
    local hum = target.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return hrp.Position end
    local vel = hrp.AssemblyLinearVelocity or Vector3.zero
    local moveDir = hum.MoveDirection
    return hrp.Position + (vel * Vector3.new(0.75, 0.5, 0.75)) * (_shootOffset / 15) + moveDir * _shootOffset
end

local function shootMurderer()
    local murderer = getMurderer()
    if not murderer then
        if Window then Window.Notify("Shoot","No murderer found",3) end
        return
    end
    local char = LocalPlayer.Character
    if not char then return end

    
    local gun = char:FindFirstChild("Gun") or char:FindFirstChild("Sheriff Gun")
    if not gun then
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if bp then
            gun = bp:FindFirstChild("Gun") or bp:FindFirstChild("Sheriff Gun")
            if gun then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then hum:EquipTool(gun) end
                task.wait(0.05)
                gun = char:FindFirstChild("Gun") or char:FindFirstChild("Sheriff Gun")
            end
        end
    end

    if not gun then
        if Window then Window.Notify("Shoot","You don't have a gun",3) end
        return
    end

    local murdererHRP = murderer.Character and murderer.Character:FindFirstChild("HumanoidRootPart")
    if not murdererHRP then
        if Window then Window.Notify("Shoot","Can't find murderer HRP",3) end
        return
    end

    local predictedPos = getPredictedPosition(murderer) or murdererHRP.Position
    local myHand = char:FindFirstChild("RightHand") or char:FindFirstChild("HumanoidRootPart")

    
    local shootRemote = gun:FindFirstChild("Shoot")
    if shootRemote then
        shootRemote:FireServer(
            CFrame.new(myHand.Position),
            CFrame.new(predictedPos)
        )
        if Window then Window.Notify("Shoot","Fired at murderer!",2) end
        return
    end

    
    local knifeLocal = gun:FindFirstChild("KnifeLocal")
    if knifeLocal then
        local createBeam = knifeLocal:FindFirstChild("CreateBeam")
        if createBeam then
            local rf = createBeam:FindFirstChild("RemoteFunction")
            if rf then
                rf:InvokeServer(1, predictedPos, "AH2")
                if Window then Window.Notify("Shoot","Fired at murderer!",2) end
                return
            end
        end
    end

    if Window then Window.Notify("Shoot","Could not find shoot remote",3) end
end


local function killEveryone()
    local char = LocalPlayer.Character
    if not char then return end
    local myHRP = char:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    local knife = char:FindFirstChild("Knife")
    if not knife then
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if bp then
            knife = bp:FindFirstChild("Knife")
            if knife then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then hum:EquipTool(knife) end
                task.wait(0.05)
                knife = char:FindFirstChild("Knife")
            end
        end
    end

    if not knife then
        if Window then Window.Notify("Kill All","You don't have a knife",3) end
        return
    end

    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.Anchored = true
                hrp.CFrame = myHRP.CFrame + myHRP.CFrame.LookVector * 1
            end
        end
    end

    
    local stabRemote = knife:FindFirstChild("Stab")
    if stabRemote then
        stabRemote:FireServer("Slash")
        if Window then Window.Notify("Kill All","Stab sent!",2) end
    else
        if Window then Window.Notify("Kill All","Stab remote not found",3) end
    end
end


local _silentAimMurderer = false
local _silentCooldown    = false

UserInputService.InputBegan:Connect(function(inp, proc)
    if proc then return end
    if _silentAimMurderer and not _silentCooldown
    and inp.UserInputType == Enum.UserInputType.MouseButton2 then
        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            local knife = char:FindFirstChild("Knife")
            if not knife then
                local bp = LocalPlayer.Backpack
                if bp then knife = bp:FindFirstChild("Knife") end
                if knife then
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum then hum:EquipTool(knife) end
                    task.wait(0.05)
                    knife = char:FindFirstChild("Knife")
                    if not knife then return end
                end
            end
            if not knife then return end

            local target = getNearestPlayer()
            if not target or not target.Character then return end
            local head = target.Character:FindFirstChild("Head")
                      or target.Character:FindFirstChild("HumanoidRootPart")
            if not head then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end

            local predictedPos = getPredictedPosition(target) or head.Position

            local thrown = knife:FindFirstChild("Events") and knife.Events:FindFirstChild("KnifeThrown")
            if thrown then
                thrown:FireServer(
                    CFrame.new(hrp.Position + Vector3.new(0,1.5,0), head.Position),
                    CFrame.new(predictedPos)
                )
            else
                local throwRemote = knife:FindFirstChild("Throw")
                if throwRemote then
                    throwRemote:FireServer(
                        CFrame.new(hrp.Position + Vector3.new(0,1.5,0)),
                        CFrame.new(predictedPos)
                    )
                end
            end

            _silentCooldown = true
            task.delay(0.3, function() _silentCooldown = false end)
        end)
    end
end)


local _antiFlingDetCon, _antiFlingNeutCon
local _antiFlingLastPos = Vector3.zero

local function toggleAntiFling(state)
    if state then
        _antiFlingDetCon = RunService.Heartbeat:Connect(function()
            for _, pl in ipairs(Players:GetPlayers()) do
                if pl ~= LocalPlayer and pl.Character and pl.Character.PrimaryPart then
                    local pp = pl.Character.PrimaryPart
                    if pp.AssemblyAngularVelocity.Magnitude > 50 or pp.AssemblyLinearVelocity.Magnitude > 100 then
                        for _, p in ipairs(pl.Character:GetDescendants()) do
                            if p:IsA("BasePart") then p.CanCollide = false end
                        end
                    end
                end
            end
        end)
        _antiFlingNeutCon = RunService.Heartbeat:Connect(function()
            if LocalPlayer.Character and LocalPlayer.Character.PrimaryPart then
                local hrp = LocalPlayer.Character.PrimaryPart
                if hrp.AssemblyLinearVelocity.Magnitude > 250 or hrp.AssemblyAngularVelocity.Magnitude > 250 then
                    hrp.AssemblyLinearVelocity  = Vector3.zero
                    hrp.AssemblyAngularVelocity = Vector3.zero
                    if _antiFlingLastPos ~= Vector3.zero then hrp.CFrame = CFrame.new(_antiFlingLastPos) end
                else
                    _antiFlingLastPos = hrp.Position
                end
            end
        end)
    else
        if _antiFlingDetCon  then _antiFlingDetCon:Disconnect()  end
        if _antiFlingNeutCon then _antiFlingNeutCon:Disconnect() end
    end
end

local function miniFling(target)
    if not target or not target.Character then return end
    local Character = LocalPlayer.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    local RootPart = Humanoid and Humanoid.RootPart
    local TCharacter = target.Character
    local THumanoid = TCharacter:FindFirstChildOfClass("Humanoid")
    local TRootPart = THumanoid and THumanoid.RootPart
    local THead = TCharacter:FindFirstChild("Head")
    local Accessory = TCharacter:FindFirstChildOfClass("Accessory")
    local Handle = Accessory and Accessory:FindFirstChild("Handle")
    if not (Character and Humanoid and RootPart) then return end
    if not TCharacter:FindFirstChildWhichIsA("BasePart") then return end
    if RootPart.Velocity.Magnitude < 50 then
        getgenv().OldPos = RootPart.CFrame
    end
    if THead then workspace.CurrentCamera.CameraSubject = THead
    elseif Handle then workspace.CurrentCamera.CameraSubject = Handle
    elseif THumanoid then workspace.CurrentCamera.CameraSubject = THumanoid end
    local FPos = function(BasePart, Pos, Ang)
        RootPart.CFrame = CFrame.new(BasePart.Position) * Pos * Ang
        Character:SetPrimaryPartCFrame(CFrame.new(BasePart.Position) * Pos * Ang)
        RootPart.Velocity = Vector3.new(9e7, 9e7*10, 9e7)
        RootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
    end
    local SFBasePart = function(BasePart)
        local TimeToWait = 2; local Time = tick(); local Angle = 0
        repeat
            if RootPart and THumanoid then
                if BasePart.Velocity.Magnitude < 50 then
                    Angle+=100
                    FPos(BasePart,CFrame.new(0,1.5,0)+THumanoid.MoveDirection*BasePart.Velocity.Magnitude/1.25,CFrame.Angles(math.rad(Angle),0,0)) task.wait()
                    FPos(BasePart,CFrame.new(0,-1.5,0)+THumanoid.MoveDirection*BasePart.Velocity.Magnitude/1.25,CFrame.Angles(math.rad(Angle),0,0)) task.wait()
                    FPos(BasePart,CFrame.new(2.25,1.5,-2.25)+THumanoid.MoveDirection*BasePart.Velocity.Magnitude/1.25,CFrame.Angles(math.rad(Angle),0,0)) task.wait()
                    FPos(BasePart,CFrame.new(-2.25,-1.5,2.25)+THumanoid.MoveDirection*BasePart.Velocity.Magnitude/1.25,CFrame.Angles(math.rad(Angle),0,0)) task.wait()
                    FPos(BasePart,CFrame.new(0,1.5,0)+THumanoid.MoveDirection,CFrame.Angles(math.rad(Angle),0,0)) task.wait()
                    FPos(BasePart,CFrame.new(0,-1.5,0)+THumanoid.MoveDirection,CFrame.Angles(math.rad(Angle),0,0)) task.wait()
                else
                    FPos(BasePart,CFrame.new(0,1.5,THumanoid.WalkSpeed),CFrame.Angles(math.rad(90),0,0)) task.wait()
                    FPos(BasePart,CFrame.new(0,-1.5,-THumanoid.WalkSpeed),CFrame.Angles(0,0,0)) task.wait()
                    FPos(BasePart,CFrame.new(0,1.5,TRootPart.Velocity.Magnitude/1.25),CFrame.Angles(math.rad(90),0,0)) task.wait()
                    FPos(BasePart,CFrame.new(0,-1.5,-TRootPart.Velocity.Magnitude/1.25),CFrame.Angles(0,0,0)) task.wait()
                    FPos(BasePart,CFrame.new(0,-1.5,0),CFrame.Angles(math.rad(90),0,0)) task.wait()
                    FPos(BasePart,CFrame.new(0,-1.5,0),CFrame.Angles(0,0,0)) task.wait()
                    FPos(BasePart,CFrame.new(0,-1.5,0),CFrame.Angles(math.rad(-90),0,0)) task.wait()
                    FPos(BasePart,CFrame.new(0,-1.5,0),CFrame.Angles(0,0,0)) task.wait()
                end
            else break end
        until BasePart.Velocity.Magnitude>500 or BasePart.Parent~=TCharacter
            or target.Parent~=Players or THumanoid.Sit
            or Humanoid.Health<=0 or tick()>Time+TimeToWait
    end
    workspace.FallenPartsDestroyHeight = 0/0
    local BV = Instance.new("BodyVelocity", RootPart)
    BV.Name="EpixVel"; BV.Velocity=Vector3.new(9e8,9e8,9e8); BV.MaxForce=Vector3.new(1/0,1/0,1/0)
    Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
    if TRootPart and THead then
        if (TRootPart.CFrame.p-THead.CFrame.p).Magnitude > 5 then SFBasePart(THead) else SFBasePart(TRootPart) end
    elseif TRootPart then SFBasePart(TRootPart)
    elseif THead     then SFBasePart(THead)
    elseif Handle    then SFBasePart(Handle) end
    BV:Destroy()
    Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
    workspace.CurrentCamera.CameraSubject = Humanoid
    repeat
        RootPart.CFrame = getgenv().OldPos*CFrame.new(0,.5,0)
        Character:SetPrimaryPartCFrame(getgenv().OldPos*CFrame.new(0,.5,0))
        Humanoid:ChangeState("GettingUp")
        for _, x in ipairs(Character:GetChildren()) do
            if x:IsA("BasePart") then x.Velocity=Vector3.zero; x.RotVelocity=Vector3.zero end
        end
        task.wait()
    until (RootPart.Position - getgenv().OldPos.p).Magnitude < 25
    workspace.FallenPartsDestroyHeight = -500
end

