local function findInWhitelist(whitelist, name)
    local nameLower = name:lower()
    
    for entry in pairs(whitelist) do
        if entry:lower() == nameLower then
            return entry
        end
    end
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.DisplayName:lower() == nameLower then
            for entry in pairs(whitelist) do
                if entry:lower() == plr.Name:lower() then
                    return entry
                end
            end
        end
    end
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Name:lower():sub(1, #nameLower) == nameLower or
           plr.DisplayName:lower():sub(1, #nameLower) == nameLower then
            for entry in pairs(whitelist) do
                if entry:lower() == plr.Name:lower() then
                    return entry
                end
            end
        end
    end
    return nil
end

local function resolvePlayerName(name)
    local nameLower = name:lower()
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Name:lower() == nameLower or plr.DisplayName:lower() == nameLower then
            return plr.Name
        end
    end
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Name:lower():sub(1, #nameLower) == nameLower or
           plr.DisplayName:lower():sub(1, #nameLower) == nameLower then
            return plr.Name
        end
    end
    return name
end


