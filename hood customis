local function silentIsKO(plr)
    if not (plr and plr.Character and SilentAimSettings.KOCheck) then return false end
    local be = plr.Character:FindFirstChild("BodyEffects"); if not be then return false end
    if be:FindFirstChild("K.O") then return be["K.O"].Value end
    if be:FindFirstChild("KO")  then return be.KO.Value end
    return false
end

local function silentIsVisible(plr)
    if not SilentAimSettings.WallCheck then return true end
    local char = plr.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    local hrp  = char.HumanoidRootPart
    local orig = Camera.CFrame.Position
    local dir  = hrp.Position - orig
    return not workspace:FindPartOnRay(Ray.new(orig, dir.Unit * dir.Magnitude), char)
end

local function silentGetNearest()
    if not SilentAimSettings.Enabled then return nil end
    local radius = SilentAimSettings.Fov.Radius
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local best, found = radius, nil
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == LocalPlayer or not plr.Character then continue end
        if not plr.Character:FindFirstChild(SilentAimSettings.Part) then continue end
        if matchesWhitelist(SilentAimSettings.Whitelist, plr) then continue end
        if silentIsKO(plr) then continue end
        if not silentIsVisible(plr) then continue end
        local sp, on = Camera:WorldToScreenPoint(plr.Character[SilentAimSettings.Part].Position)
        if not on then continue end
        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if d < best then best=d; found=plr end
    end
    return found
end

