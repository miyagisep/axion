        box={top=newLine(1),bottom=newLine(1),left=newLine(1),right=newLine(1),fill=newQuad(nil,true,0.7,1)},
        healthBar={bg=newLine(4,Color3.new(0,0,0),2),bar=newLine(2,Color3.fromRGB(0,255,0),3)},
        name=newText(13),distance=newText(11,Color3.fromRGB(200,200,200)),
        tracer=newLine(1),skeleton={},highlight=nil,chams={},
    }
    for i=1,#skeletonBones do d.skeleton[i]=newLine(1) end
    playerESP[plr]=d
end

local function destroyESPEntry(d)
    for _,v in pairs(d.box) do pcall(function() v:Remove() end) end
    pcall(function() d.healthBar.bg:Remove() end)
    pcall(function() d.healthBar.bar:Remove() end)
    pcall(function() d.name:Remove() end)
    pcall(function() d.distance:Remove() end)
    pcall(function() d.tracer:Remove() end)
    for _,l in ipairs(d.skeleton) do pcall(function() l:Remove() end) end
    if d.highlight and d.highlight.Parent then d.highlight:Destroy(); d.highlight=nil end
    for _,inst in ipairs(d.chams) do
        if inst and inst.Parent then inst:Destroy() end
    end
    d.chams={}
end

local function removeESP(plr)
    local d=playerESP[plr]; if not d then return end
    destroyESPEntry(d)
    playerESP[plr]=nil
end

local function hideESP(d)
    for _,v in pairs(d.box) do v.Visible=false end
    d.healthBar.bg.Visible=false; d.healthBar.bar.Visible=false
    d.name.Visible=false; d.distance.Visible=false; d.tracer.Visible=false
    for _,l in ipairs(d.skeleton) do l.Visible=false end
end

local function updateESPPlayer(plr,d)
    local char=plr.Character; if not char then hideESP(d) return end
    local hrp=char:FindFirstChild("HumanoidRootPart")
    local hum=char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum or hum.Health<=0 then hideESP(d) return end
    local minB,maxB=getCharBounds(char); if not minB then hideESP(d) return end
    local topC=Vector3.new((minB.X+maxB.X)/2,maxB.Y,(minB.Z+maxB.Z)/2)
    local botC=Vector3.new((minB.X+maxB.X)/2,minB.Y,(minB.Z+maxB.Z)/2)
    local sTop,_,dTop=w2s(topC); local sBot=w2s(botC)
    if dTop<0 then hideESP(d) return end
    local height=math.abs(sTop.Y-sBot.Y); local width=height*0.6
    local L,R,T,B=sTop.X-width/2,sTop.X+width/2,sTop.Y,sBot.Y
    local dist=math.floor((hrp.Position-Camera.CFrame.Position).Magnitude)

    if ESPSettings.Box then
        d.box.top.From=Vector2.new(L,T); d.box.top.To=Vector2.new(R,T)
        d.box.bottom.From=Vector2.new(L,B); d.box.bottom.To=Vector2.new(R,B)
        d.box.left.From=Vector2.new(L,T); d.box.left.To=Vector2.new(L,B)
        d.box.right.From=Vector2.new(R,T); d.box.right.To=Vector2.new(R,B)
        for _,b in pairs({d.box.top,d.box.bottom,d.box.left,d.box.right}) do
            b.Color=ESPSettings.BoxColor; b.Transparency=1; b.Visible=true
        end
        if ESPSettings.BoxFill then
            d.box.fill.PointA=Vector2.new(L,T); d.box.fill.PointB=Vector2.new(R,T)
            d.box.fill.PointC=Vector2.new(R,B); d.box.fill.PointD=Vector2.new(L,B)
            d.box.fill.Color=ESPSettings.BoxFillColor
            d.box.fill.Transparency=ESPSettings.BoxFillTrans; d.box.fill.Visible=true
        else d.box.fill.Visible=false end
    else for _,b in pairs(d.box) do b.Visible=false end end

    if ESPSettings.HealthBar then
        local ratio=math.clamp(hum.Health/hum.MaxHealth,0,1)
        local barX=ESPSettings.HealthBarSide=="Left" and L-5 or R+5
        d.healthBar.bg.From=Vector2.new(barX,T); d.healthBar.bg.To=Vector2.new(barX,B)
        d.healthBar.bar.From=Vector2.new(barX,B); d.healthBar.bar.To=Vector2.new(barX,B-height*ratio)
        d.healthBar.bg.Thickness=4; d.healthBar.bg.Transparency=1; d.healthBar.bg.Visible=true
        d.healthBar.bar.Thickness=2; d.healthBar.bar.Color=Color3.fromHSV(ratio*120/360,1,1)
        d.healthBar.bar.Transparency=1; d.healthBar.bar.Visible=true
    else d.healthBar.bg.Visible=false; d.healthBar.bar.Visible=false end

    if ESPSettings.Names then
        d.name.Text=plr.DisplayName.." (@"..plr.Name..")"
        d.name.Color=ESPSettings.NameColor
        d.name.Position=Vector2.new(sTop.X,T-16); d.name.Center=true; d.name.Visible=true
    else d.name.Visible=false end

    if ESPSettings.Distance then
        d.distance.Text=dist.." studs"; d.distance.Color=ESPSettings.DistanceColor
        d.distance.Position=Vector2.new(sTop.X,B+2); d.distance.Center=true; d.distance.Visible=true
    else d.distance.Visible=false end

    if ESPSettings.Tracers then
        local vpS=Camera.ViewportSize
        local oy=ESPSettings.TracerOrigin=="Bottom" and vpS.Y or 0
        d.tracer.From=Vector2.new(vpS.X/2,oy); d.tracer.To=Vector2.new(sBot.X,sBot.Y)
        d.tracer.Color=ESPSettings.TracerColor; d.tracer.Transparency=1; d.tracer.Visible=true
    else d.tracer.Visible=false end

    if ESPSettings.Skeleton then
        for i,bone in ipairs(skeletonBones) do
            local p0=char:FindFirstChild(bone[1]); local p1=char:FindFirstChild(bone[2])
            if p0 and p1 then
                local s0,on0=w2s(p0.Position); local s1,on1=w2s(p1.Position)
                if on0 and on1 then
                    d.skeleton[i].From=s0; d.skeleton[i].To=s1
                    d.skeleton[i].Color=ESPSettings.SkeletonColor
                    d.skeleton[i].Transparency=1; d.skeleton[i].Visible=true
                else d.skeleton[i].Visible=false end
            else d.skeleton[i].Visible=false end
        end
    else for _,l in ipairs(d.skeleton) do l.Visible=false end end

    if ESPSettings.Highlight then
        if not d.highlight or not d.highlight.Parent then
            local hl=Instance.new("Highlight")
            hl.FillColor=ESPSettings.HLFillColor; hl.OutlineColor=ESPSettings.HLOutlineColor
            hl.FillTransparency=ESPSettings.HLFillTrans; hl.OutlineTransparency=ESPSettings.HLOutTrans
            hl.Adornee=char; hl.Parent=espFolder; d.highlight=hl
        else
            d.highlight.FillColor=ESPSettings.HLFillColor; d.highlight.OutlineColor=ESPSettings.HLOutlineColor
            d.highlight.FillTransparency=ESPSettings.HLFillTrans; d.highlight.OutlineTransparency=ESPSettings.HLOutTrans
        end
    else
        if d.highlight and d.highlight.Parent then d.highlight:Destroy(); d.highlight=nil end
    end

    if ESPSettings.Chams then
        if #d.chams==0 then
            for _,part in ipairs(char:GetChildren()) do
                if part:IsA("BasePart") then
                    local box=Instance.new("BoxHandleAdornment")
                    box.Size=part.Size+Vector3.new(.05,.05,.05); box.Color3=ESPSettings.ChamsColor
                    box.AlwaysOnTop=true; box.ZIndex=1; box.Transparency=ESPSettings.ChamsTrans
                    box.Adornee=part; box.Parent=espFolder; table.insert(d.chams,box)
                end
            end
        else
            for _,box in ipairs(d.chams) do
                box.Color3=ESPSettings.ChamsColor; box.Transparency=ESPSettings.ChamsTrans
            end
        end
    else
        for _,inst in ipairs(d.chams) do if inst.Parent then inst:Destroy() end end
        d.chams={}
    end
end

