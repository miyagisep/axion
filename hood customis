local function getPart(char, name)
    if not char then return nil end
    local p = char:FindFirstChild(name); if p then return p end
    if name=="Torso"      then return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Head") end
    if name=="UpperTorso" then return char:FindFirstChild("Torso")     or char:FindFirstChild("Head") end
    return char:FindFirstChild("Head")
end

local function isKO(plr)
    local char = plr.Character; if not char then return false end
    local be = char:FindFirstChild("BodyEffects"); if not be then return false end
    local ko = be:FindFirstChild("K.O") or be:FindFirstChild("KO")
    return ko and ko.Value == true
end

local function getPredictedPos(char, partName, amt)
    local part = getPart(char, partName); if not part then return nil end
    local hrp  = char:FindFirstChild("HumanoidRootPart"); if not hrp then return part.Position end
    local vel  = hrp.AssemblyLinearVelocity
    if not vel or vel.Magnitude==0 then pcall(function() vel=hrp.Velocity end) end
    if not vel then return part.Position end
    return part.Position + vel * amt
end

local function matchesWhitelist(whitelist, plr)
    if not whitelist then return false end
    local nameLower    = plr.Name:lower()
    local displayLower = plr.DisplayName:lower()
    for entry in pairs(whitelist) do
        local e = entry:lower()
        if nameLower == e or displayLower == e then
            return true
        end
    end
    return false
end

local function GetClosest(fov, part, whitelist, ignoreKO)
    local closest, best = nil, fov
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            if matchesWhitelist(whitelist, plr) then continue end
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                if ignoreKO and isKO(plr) then continue end
                local tp = getPart(plr.Character, part)
                if tp then
                    local sp, on = Camera:WorldToViewportPoint(tp.Position)
                    if on then
                        local d = (Vector2.new(sp.X,sp.Y)-center).Magnitude
                        if d < best then closest=plr; best=d end
                    end
                end
            end
        end
    end
    return closest
end

local function GetPlayerAtCrosshair()
    local closest, best = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health>0 then
                local sp, on = Camera:WorldToViewportPoint(hrp.Position)
                if on then
                    local d = (Vector2.new(sp.X,sp.Y)-center).Magnitude
                    if d < best then closest=plr; best=d end
                end
            end
        end
    end
    return closest
end

local function matchesBind(inp, bind)
    if not bind then return false end
    if bind.type == "mouse" then
        if inp.UserInputType ~= bind.value then return false end
        return true
    elseif bind.type == "key" then
        if inp.UserInputType ~= Enum.UserInputType.Keyboard then return false end
        if inp.KeyCode ~= bind.value then return false end
        return true
    end
    return false
end


local function matchesMenuBind(inp, bind)
    if not bind then return false end
    if bind.type ~= "key" then return false end
    if inp.UserInputType ~= Enum.UserInputType.Keyboard then return false end
    if inp.KeyCode ~= bind.value then return false end
    if bind.value == Enum.KeyCode.Unknown then return false end
    return true
end


