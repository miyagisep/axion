local function getCharBounds(char)
    local minX,minY,minZ=math.huge,math.huge,math.huge
    local maxX,maxY,maxZ=-math.huge,-math.huge,-math.huge
    local found=false
    for _,p in ipairs(char:GetChildren()) do
        if p:IsA("BasePart") then found=true
            local pos,s=p.Position,p.Size
            minX=math.min(minX,pos.X-s.X/2);minY=math.min(minY,pos.Y-s.Y/2);minZ=math.min(minZ,pos.Z-s.Z/2)
            maxX=math.max(maxX,pos.X+s.X/2);maxY=math.max(maxY,pos.Y+s.Y/2);maxZ=math.max(maxZ,pos.Z+s.Z/2)
        end
    end
    if not found then return nil end
    return Vector3.new(minX,minY,minZ),Vector3.new(maxX,maxY,maxZ)
end
local function w2s(pos) local sp,on=Camera:WorldToViewportPoint(pos);return Vector2.new(sp.X,sp.Y),on,sp.Z end

local function createESP(plr)
