    local function getPart(char,name)
        if not char then return nil end
        local p=char:FindFirstChild(name); if p then return p end
        if name=="Torso" then return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Head") end
        if name=="UpperTorso" then return char:FindFirstChild("Torso") or char:FindFirstChild("Head") end
        return char:FindFirstChild("Head")
    end

    local function getClosestAim(fov)
        local best,closest=fov,nil
        local cx=Camera.ViewportSize.X/2; local cy=Camera.ViewportSize.Y/2
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr==LocalPlayer or not plr.Character then continue end
            local nl=plr.Name:lower()
            local dl=plr.DisplayName:lower()
            local wl=false
            for entry in pairs(AimbotSettings.Whitelist) do
                local e=entry:lower()
                if nl:sub(1,#e)==e or dl:sub(1,#e)==e then wl=true; break end
            end
            if wl then continue end
            local hum=plr.Character:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health<=0 then continue end
            if AimbotSettings.TeamCheck and LocalPlayer.Team and plr.Team==LocalPlayer.Team then continue end
            local tp=getPart(plr.Character,AimbotSettings.TargetPart); if not tp then continue end
            if AimbotSettings.WallCheck then
                local params=RaycastParams.new()
                params.FilterType=Enum.RaycastFilterType.Exclude
                params.FilterDescendantsInstances={LocalPlayer.Character,Camera}
                local ray=workspace:Raycast(Camera.CFrame.Position,tp.Position-Camera.CFrame.Position,params)
                if not (ray and ray.Instance and ray.Instance:IsDescendantOf(plr.Character)) then continue end
            end
            local tp=getPart(plr.Character,AimbotSettings.TargetPart); if not tp then continue end
            local sp,on=Camera:WorldToViewportPoint(tp.Position)
            if on then
                local d=(Vector2.new(sp.X,sp.Y)-Vector2.new(cx,cy)).Magnitude
                if d<best then best=d; closest=plr end
            end
        end
        return closest
    end

    RunService.RenderStepped:Connect(function()
        local cx=Camera.ViewportSize.X/2; local cy=Camera.ViewportSize.Y/2
        AimbotCircle.Position=Vector2.new(cx,cy); AimbotCircle.Radius=AimbotSettings.FOV
        AimbotCircle.Color=AimbotSettings.FOVColor
        AimbotCircle.Visible=AimbotSettings.ShowFOV and AimbotSettings.Enabled and not _hidden
        if not (AimbotSettings.Enabled and _aimBindState) then
            if not AimbotSettings.Sticky then AimbotSettings.StickyTarget=nil end; return
        end
        local target=nil
        if AimbotSettings.Sticky and AimbotSettings.StickyTarget then
            local sc=AimbotSettings.StickyTarget
            local hum=sc.Character and sc.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health>0 then target=sc else AimbotSettings.StickyTarget=nil end
        end
        if not target then
            target=getClosestAim(AimbotSettings.FOV)
            if AimbotSettings.Sticky and target then AimbotSettings.StickyTarget=target end
        end
        if not (target and target.Character) then return end
        local tp=getPart(target.Character,AimbotSettings.TargetPart); if not tp then return end
        Camera.CFrame=Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position,tp.Position),AimbotSettings.Smoothness)
    end)

