    local function fullUnload()
        AimbotSettings.Enabled=false; _aimBindState=false; AimbotSettings.StickyTarget=nil
        ESPSettings.Enabled=false
        PlayerSettings.Fly=false; stopFly()
        PlayerSettings.Speed=false; PlayerSettings.JumpBoost=false
        PlayerSettings.InfiniteJump=false; PlayerSettings.NoClip=false
        MiscSettings.AntiFling=false
        MiscSettings.AntiAFK=false; stopAntiAFK()
        MiscSettings.HitboxExp=false
        
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr~=LocalPlayer then
                pcall(function()
                    local hrp=plr.Character.HumanoidRootPart
                    hrp.Size=Vector3.new(2,2,1)
                    hrp.Transparency=1
                    hrp.Material=Enum.Material.SmoothPlastic
                    hrp.CanCollide=true
                end)
            end
        end
        _hidden=false
        local hum=getHum()
        if hum then hum.WalkSpeed=16; hum.JumpPower=50; hum.PlatformStand=false end
        workspace.Gravity=_origGravity
        applyFullbright(false); applyFog(false); applyShadows(false)
        Camera.FieldOfView=_origFOV
        LocalPlayer.CameraMaxZoomDistance=_origMaxZoom
        for plr,_ in pairs(playerESP) do destroyESP(plr) end
        AimbotCircle.Visible=false; pcall(function() AimbotCircle:Remove() end)
        task.wait(0.1)
        pcall(function()
            if Window._ScreenGui and Window._ScreenGui.Parent then
                Window._ScreenGui:Destroy()
            end
        end)
    end

