    local function newLine(t,c) local l=Drawing.new("Line");l.Thickness=t or 1;l.Color=c or Color3.new(1,1,1);l.Transparency=1;l.Visible=false;return l end
    local function newText(s,c) local t=Drawing.new("Text");t.Size=s or 13;t.Color=c or Color3.new(1,1,1);t.Outline=true;t.OutlineColor=Color3.new(0,0,0);t.Transparency=1;t.Visible=false;return t end

    local function createESP(plr)
        if playerESP[plr] or plr==LocalPlayer then return end
        local d={
            box={newLine(1),newLine(1),newLine(1),newLine(1)},
            tName=newText(13), tDist=newText(11),
            tracer=newLine(1),
            skel={}, rigType=nil,
        }
        for i=1,14 do d.skel[i]=newLine(1) end
        playerESP[plr]=d
    end

    local function destroyESP(plr)
        local d=playerESP[plr]; if not d then return end
        for _,l in ipairs(d.box) do pcall(function() l:Remove() end) end
        pcall(function() d.tName:Remove() end); pcall(function() d.tDist:Remove() end)
        pcall(function() d.tracer:Remove() end)
        for _,l in ipairs(d.skel) do pcall(function() l:Remove() end) end
        playerESP[plr]=nil
    end

    local function hideESP(d)
        for _,l in ipairs(d.box) do l.Visible=false end
        d.tName.Visible=false; d.tDist.Visible=false; d.tracer.Visible=false
        for _,l in ipairs(d.skel) do l.Visible=false end
    end

    local function getBox(char)
        local minX,minY,maxX,maxY=math.huge,math.huge,-math.huge,-math.huge; local found=false
        for _,p in ipairs(char:GetChildren()) do
            if not p:IsA("BasePart") then continue end
            local sx,sy,sz=p.Size.X/2,p.Size.Y/2,p.Size.Z/2
            for _,off in ipairs({Vector3.new(sx,sy,sz),Vector3.new(-sx,sy,sz),Vector3.new(sx,-sy,sz),Vector3.new(-sx,-sy,sz),Vector3.new(sx,sy,-sz),Vector3.new(-sx,sy,-sz),Vector3.new(sx,-sy,-sz),Vector3.new(-sx,-sy,-sz)}) do
                local sp,on=Camera:WorldToViewportPoint(p.CFrame:PointToWorldSpace(off))
                if not on or sp.Z<=0 then continue end
                found=true
                if sp.X<minX then minX=sp.X end; if sp.Y<minY then minY=sp.Y end
                if sp.X>maxX then maxX=sp.X end; if sp.Y>maxY then maxY=sp.Y end
            end
        end
        if not found then return nil end
        return minX,minY,maxX,maxY
    end

    local function updateESP(plr,d)
        local char=plr.Character; if not char then hideESP(d) return end
        local hrp=char:FindFirstChild("HumanoidRootPart")
        local hum=char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health<=0 then hideESP(d) return end
        local L,T,R,B=getBox(char); if not L then hideESP(d) return end
        local W=R-L; local H=B-T; local cx=(L+R)/2
        local dist=math.floor((hrp.Position-Camera.CFrame.Position).Magnitude)
        local fs=math.clamp(H-3,6,14)

        if ESPSettings.Box then
            local bc=ESPSettings.BoxColor
            d.box[1].From=Vector2.new(L,T); d.box[1].To=Vector2.new(R,T); d.box[1].Color=bc; d.box[1].Visible=true
            d.box[2].From=Vector2.new(L,B); d.box[2].To=Vector2.new(R,B); d.box[2].Color=bc; d.box[2].Visible=true
            d.box[3].From=Vector2.new(L,T); d.box[3].To=Vector2.new(L,B); d.box[3].Color=bc; d.box[3].Visible=true
            d.box[4].From=Vector2.new(R,T); d.box[4].To=Vector2.new(R,B); d.box[4].Color=bc; d.box[4].Visible=true
        else for _,l in ipairs(d.box) do l.Visible=false end end

        if ESPSettings.Name then
            d.tName.Text=plr.DisplayName; d.tName.Color=ESPSettings.NameColor
            d.tName.Size=fs; d.tName.Position=Vector2.new(cx,T-fs-2); d.tName.Center=true; d.tName.Visible=true
        else d.tName.Visible=false end

        if ESPSettings.Distance then
            d.tDist.Text=dist.." studs"; d.tDist.Color=ESPSettings.DistColor
            d.tDist.Size=math.max(fs-2,6); d.tDist.Position=Vector2.new(cx,B+2); d.tDist.Center=true; d.tDist.Visible=true
        else d.tDist.Visible=false end

        if ESPSettings.Tracers then
            d.tracer.From=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y)
            d.tracer.To=Vector2.new(cx,B); d.tracer.Color=ESPSettings.TracerColor
            d.tracer.Transparency=1; d.tracer.Visible=true
        else d.tracer.Visible=false end

        if ESPSettings.Skeleton then
            if not d.rigType then d.rigType=char:FindFirstChild("Torso") and "R6" or "R15" end
            local bones=d.rigType=="R6" and BONES_R6 or BONES
            for i=1,14 do d.skel[i].Visible=false end
            for i,bone in ipairs(bones) do
                local p0=char:FindFirstChild(bone[1]); local p1=char:FindFirstChild(bone[2])
                if p0 and p1 then
                    local s0,on0=Camera:WorldToViewportPoint(p0.Position)
                    local s1,on1=Camera:WorldToViewportPoint(p1.Position)
                    if on0 and on1 and s0.Z>0 and s1.Z>0 then
                        d.skel[i].From=Vector2.new(s0.X,s0.Y); d.skel[i].To=Vector2.new(s1.X,s1.Y)
                        d.skel[i].Color=ESPSettings.SkelColor; d.skel[i].Transparency=1; d.skel[i].Visible=true
                    end
                end
            end
        else for i=1,14 do d.skel[i].Visible=false end end
    end

