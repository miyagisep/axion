local function closeDropdown()
    _dropOpen = false
    Tw(DropList,  {Size=UDim2.new(0,DropList.AbsoluteSize.X,0,0)}, 0.15, Enum.EasingStyle.Quint):Play()
    Tw(DropArrow, {Rotation=0}, 0.15):Play()
    Tw(DBStroke,  {Color=C.Border}, 0.15):Play()
    task.wait(0.16); DropList.Visible = false
end

local function openDropdown()
    _dropOpen = true
    local abs   = DropBtn.AbsolutePosition
    local absSz = DropBtn.AbsoluteSize
    local totalH = #GAMES * 36 + 16
    DropList.Position = UDim2.fromOffset(abs.X, abs.Y + absSz.Y + 4)
    DropList.Size     = UDim2.fromOffset(absSz.X, 0)
    DropList.Visible  = true
    Tw(DropList,  {Size=UDim2.fromOffset(absSz.X, totalH)}, 0.2, Enum.EasingStyle.Back):Play()
    Tw(DropArrow, {Rotation=180}, 0.18):Play()
    Tw(DBStroke,  {Color=C.Accent}, 0.15):Play()
end

