local function Tw(obj, props, t, style, dir)
    return TweenService:Create(obj,
        TweenInfo.new(t or 0.25, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out),
        props)
end
local function makeCorner(p, r)
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 6); c.Parent = p; return c
end
local function makeStroke(p, col, thick, trans)
    local s = Instance.new("UIStroke")
    s.Color = col or C.Border; s.Thickness = thick or 1; s.Transparency = trans or 0
    s.Parent = p; return s
end
local function protect(gui)
    for _, v in ipairs(CoreGui:GetChildren()) do
        if v.Name == gui.Name then v:Destroy() end
    end
    if gethui then
        for _, v in ipairs(gethui():GetChildren()) do
            if v.Name == gui.Name then v:Destroy() end
        end
    end
    if syn and syn.protect_gui then syn.protect_gui(gui); gui.Parent = CoreGui
    elseif gethui then gui.Parent = gethui()
    else gui.Parent = CoreGui end
end

local function StartSnow(parent)
    local cont = Instance.new("Frame", parent)
    cont.Size = UDim2.new(1,0,1,0); cont.BackgroundTransparency = 1
    cont.ClipsDescendants = true; cont.ZIndex = 0; cont.Name = "Snow"
    local flakes = {}
    for i = 1, 60 do
        local sz = math.random(2,4)
        local f = Instance.new("Frame", cont)
        f.Size = UDim2.new(0,sz,0,sz); f.BackgroundColor3 = C.White
        f.BackgroundTransparency = math.random(40,75)/100
        f.BorderSizePixel = 0; f.ZIndex = 1; makeCorner(f,sz)
        flakes[i] = { frame=f, x=math.random(0,1000)/1000, y=math.random(-20,100)/100,
                      speed=math.random(2,7)/1000, drift=math.random(-3,3)/10000 }
        f.Position = UDim2.new(flakes[i].x,0,flakes[i].y,0)
    end
    RunService.Heartbeat:Connect(function(dt)
        if not cont or not cont.Parent then return end
        for _, fl in ipairs(flakes) do
            fl.y=fl.y+fl.speed*dt*60; fl.x=fl.x+fl.drift*dt*60
            if fl.y>1.05 then fl.y=-0.05; fl.x=math.random(0,1000)/1000 end
            if fl.x<0 then fl.x=1 end; if fl.x>1 then fl.x=0 end
            fl.frame.Position = UDim2.new(fl.x,0,fl.y,0)
        end
    end)
end

