    SilentSettings.Enabled = false
    ESPSettings.Enabled    = false
    _hidden                = false
    for model,_ in pairs(modelESP) do removeESPForModel(model) end
    modelESP = {}
    AimbotCircle.Visible = false; SilentCircle.Visible = false
    pcall(function() AimbotCircle:Remove() end)
    pcall(function() SilentCircle:Remove() end)
    if espFolder and espFolder.Parent then espFolder:Destroy() end
    task.wait(0.1)
    pcall(function()
        if Window._ScreenGui and Window._ScreenGui.Parent then
            Window._ScreenGui:Destroy()
        end
    end)
end


