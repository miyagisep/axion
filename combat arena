    end
end


local AimbotSettings = {
    Enabled    = false,
    FOV        = 50,
    ShowFOV    = true,
    FOVColor   = Color3.fromRGB(255, 255, 255),
    Smoothness = 1,
    TargetPart = "Head",
    Sticky     = false,
    StickyTarget = nil,
}
local _aimBindState = false
local _aimMode      = "Hold"
local _aimBindObj   = nil

local _hidden = false

local AimbotCircle    = Drawing.new("Circle")
AimbotCircle.Thickness = 1.5
AimbotCircle.NumSides  = 64
AimbotCircle.Filled    = false
AimbotCircle.Visible   = false

RunService.RenderStepped:Connect(function()
    local cx = Camera.ViewportSize.X / 2
    local cy = Camera.ViewportSize.Y / 2

    SilentCircle.Position = Vector2.new(cx, cy)
    SilentCircle.Radius   = SilentSettings.FOV
    SilentCircle.Color    = SilentSettings.FOVColor
    SilentCircle.Visible  = SilentSettings.ShowFOV and SilentSettings.Enabled and not _hidden

    AimbotCircle.Position = Vector2.new(cx, cy)
    AimbotCircle.Radius   = AimbotSettings.FOV
    AimbotCircle.Color    = AimbotSettings.FOVColor
    AimbotCircle.Visible  = AimbotSettings.ShowFOV and AimbotSettings.Enabled and not _hidden

    if not (AimbotSettings.Enabled and _aimBindState) then
        if not AimbotSettings.Sticky then AimbotSettings.StickyTarget = nil end
        return
    end

    local mob = nil
    if AimbotSettings.Sticky and AimbotSettings.StickyTarget then
        local m = AimbotSettings.StickyTarget
        local hum = m and m.Parent and m:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then mob = m
        else AimbotSettings.StickyTarget = nil end
    end
    if not mob then
        mob = getClosestEnemy(AimbotSettings.FOV)
        if AimbotSettings.Sticky and mob then AimbotSettings.StickyTarget = mob end
    end
    if not mob then return end

    local part = mob:FindFirstChild(AimbotSettings.TargetPart) or mob:FindFirstChild("Head")
    if not part then return end

    local prevType = Camera.CameraType
    Camera.CameraType = Enum.CameraType.Scriptable
    Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, part.Position), AimbotSettings.Smoothness)
    Camera.CameraType = prevType
end)

local function isAimInput(inp)
    if not _aimBindObj then return false end
    return matchesBind(inp, _aimBindObj.Value)
end
UserInputService.InputBegan:Connect(function(inp, proc)
    if proc or not AimbotSettings.Enabled then return end
    if isAimInput(inp) then
        if _aimMode == "Hold" then _aimBindState = true
        else _aimBindState = not _aimBindState; if not _aimBindState then AimbotSettings.StickyTarget = nil end end
    end
end)
UserInputService.InputEnded:Connect(function(inp)
    if not AimbotSettings.Enabled or _aimMode ~= "Hold" then return end
    if isAimInput(inp) then _aimBindState = false; AimbotSettings.StickyTarget = nil end
end)


