local function newLine(t,c) local l=Drawing.new("Line");l.Thickness=t or 1;l.Color=c or Color3.new(1,1,1);l.Visible=false;return l end

local function makeBillboard(char, name, offsetY, textSize)
    local head = char and char:FindFirstChild("Head")
    if not head then return nil end
    if head:FindFirstChild(name) then head:FindFirstChild(name):Destroy() end
    local bb = Instance.new("BillboardGui")
    bb.Name = name; bb.AlwaysOnTop = true
    bb.Size = UDim2.new(0, 140, 0, 20)
    bb.StudsOffset = Vector3.new(0, offsetY, 0)
    bb.Adornee = head; bb.Parent = head
    local lbl = Instance.new("TextLabel", bb)
    lbl.Size = UDim2.new(1,0,1,0); lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.new(1,1,1); lbl.TextStrokeTransparency = 0
    lbl.TextStrokeColor3 = Color3.new(0,0,0)
    lbl.Font = Enum.Font.GothamBold; lbl.TextSize = textSize or 13; lbl.Text = ""
    return bb
end

local function createESPForModel(model)
    if modelESP[model] then return end
    modelESP[model] = {
        box    = {top=newLine(1),bottom=newLine(1),left=newLine(1),right=newLine(1)},
        hpBg   = newLine(4, Color3.new(0,0,0)),
        hpBar  = newLine(2, Color3.fromRGB(0,255,0)),
        tracer = newLine(1),
        bb=nil, bbDist=nil, hl=nil,
    }
end

local function removeESPForModel(model)
    local d = modelESP[model]; if not d then return end
    for _,v in pairs(d.box) do pcall(function() v:Remove() end) end
    pcall(function() d.hpBg:Remove() end); pcall(function() d.hpBar:Remove() end)
    pcall(function() d.tracer:Remove() end)
    if d.bb and d.bb.Parent then d.bb:Destroy() end
    if d.bbDist and d.bbDist.Parent then d.bbDist:Destroy() end
    if d.hl and d.hl.Parent then d.hl:Destroy() end
    modelESP[model] = nil
end

local function hideESPData(d)
    for _,v in pairs(d.box) do v.Visible=false end
    d.hpBg.Visible=false; d.hpBar.Visible=false; d.tracer.Visible=false
    if d.bb then d.bb.Enabled=false end
    if d.bbDist then d.bbDist.Enabled=false end
end

local function getScreenBox(char)
    local minSX,minSY,maxSX,maxSY = math.huge,math.huge,-math.huge,-math.huge
    local found = false
    for _,p in ipairs(char:GetChildren()) do
        if not p:IsA("BasePart") then continue end
        local sx,sy,sz = p.Size.X/2, p.Size.Y/2, p.Size.Z/2
        local corners = {
            Vector3.new( sx, sy, sz), Vector3.new(-sx, sy, sz),
            Vector3.new( sx,-sy, sz), Vector3.new(-sx,-sy, sz),
            Vector3.new( sx, sy,-sz), Vector3.new(-sx, sy,-sz),
            Vector3.new( sx,-sy,-sz), Vector3.new(-sx,-sy,-sz),
        }
        for _,offset in ipairs(corners) do
            local worldPos = p.CFrame:PointToWorldSpace(offset)
            local sp, on = Camera:WorldToScreenPoint(worldPos)
            if not on or sp.Z <= 0 then continue end
            found = true
            if sp.X < minSX then minSX = sp.X end
            if sp.Y < minSY then minSY = sp.Y end
            if sp.X > maxSX then maxSX = sp.X end
            if sp.Y > maxSY then maxSY = sp.Y end
        end
    end
    if not found then return nil end
    return minSX, minSY, maxSX, maxSY
end

local function updateESPModel(model, d, label, boxColor)
    local hum = model:FindFirstChildOfClass("Humanoid")
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if not hum or hum.Health<=0 or not hrp then hideESPData(d) return end
    local L,T,R,B = getScreenBox(model)
    if not L then hideESPData(d) return end
    local h = B-T; if h<1 then hideESPData(d) return end
    local dist = math.floor((hrp.Position-Camera.CFrame.Position).Magnitude)

    if ESPSettings.Box then
        d.box.top.From=Vector2.new(L,T);    d.box.top.To=Vector2.new(R,T)
        d.box.bottom.From=Vector2.new(L,B); d.box.bottom.To=Vector2.new(R,B)
        d.box.left.From=Vector2.new(L,T);   d.box.left.To=Vector2.new(L,B)
        d.box.right.From=Vector2.new(R,T);  d.box.right.To=Vector2.new(R,B)
        for _,b in pairs(d.box) do b.Color=boxColor; b.Visible=true end
    else for _,b in pairs(d.box) do b.Visible=false end end

    d.hpBg.Visible=false; d.hpBar.Visible=false

    if ESPSettings.Names then
        if not d.bb or not d.bb.Parent then d.bb = makeBillboard(model, "KXESP_Name", 1.5, 13) end
        if d.bb then
            local lbl = d.bb:FindFirstChildOfClass("TextLabel")
            if lbl then lbl.Text=label; lbl.TextColor3=ESPSettings.NamesColor end
            d.bb.Enabled=true
        end
    else if d.bb then d.bb.Enabled=false end end

    if ESPSettings.Distance then
        if not d.bbDist or not d.bbDist.Parent then d.bbDist = makeBillboard(model, "KXESP_Dist", -1.5, 11) end
        if d.bbDist then
            local lbl = d.bbDist:FindFirstChildOfClass("TextLabel")
            if lbl then lbl.Text=dist.."m"; lbl.TextColor3=Color3.fromRGB(200,200,200) end
            d.bbDist.Enabled=true
        end
    else if d.bbDist then d.bbDist.Enabled=false end end

    if ESPSettings.Tracers then
        local cx2 = (L+R)/2
        local oy = ESPSettings.TracerOrigin == "Bottom" and Camera.ViewportSize.Y or 0
        d.tracer.From=Vector2.new(Camera.ViewportSize.X/2, oy)
        d.tracer.To=Vector2.new(cx2,B)
        d.tracer.Color=ESPSettings.TracerColor; d.tracer.Visible=true
    else d.tracer.Visible=false end

    if ESPSettings.Highlight then
        if not d.hl or not d.hl.Parent then
            local hl=Instance.new("Highlight")
            hl.FillColor=ESPSettings.HLFillColor; hl.OutlineColor=ESPSettings.HLOutlineColor
            hl.FillTransparency=ESPSettings.HLFillTrans; hl.OutlineTransparency=ESPSettings.HLOutTrans
            hl.Adornee=model; hl.Parent=espFolder; d.hl=hl
        else
            d.hl.FillColor=ESPSettings.HLFillColor; d.hl.OutlineColor=ESPSettings.HLOutlineColor
            d.hl.FillTransparency=ESPSettings.HLFillTrans; d.hl.OutlineTransparency=ESPSettings.HLOutTrans
        end
    else if d.hl and d.hl.Parent then d.hl:Destroy(); d.hl=nil end end
end


local function onPlayerAdded(plr)
    if plr == LocalPlayer then return end
    plr.CharacterAdded:Connect(function(char)
        local d = modelESP[char]
        if d then
            if d.bb and d.bb.Parent then d.bb:Destroy(); d.bb=nil end
            if d.bbDist and d.bbDist.Parent then d.bbDist:Destroy(); d.bbDist=nil end
            if d.hl and d.hl.Parent then d.hl:Destroy(); d.hl=nil end
        end
    end)
end
for _,p in ipairs(Players:GetPlayers()) do onPlayerAdded(p) end
Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(function(plr)
    local char = plr.Character
    if char then removeESPForModel(char) end
end)

RunService.RenderStepped:Connect(function()
    
    local activeModels = {}

    if not ESPSettings.Enabled or _hidden then
        for _,d in pairs(modelESP) do
            hideESPData(d)
            if d.hl and d.hl.Parent then d.hl:Destroy(); d.hl=nil end
        end
        return
    end
    
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local char = plr.Character; if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health<=0 then continue end
        local ally = isSameTeamModel(char)
        if ally and ESPSettings.TeamCheck then continue end
        local boxColor = ally and ESPSettings.AllyColor or ESPSettings.BoxColor
        activeModels[char] = {label=plr.DisplayName, color=boxColor}
    end

    
    for model, info in pairs(activeModels) do
        if not modelESP[model] then createESPForModel(model) end
        updateESPModel(model, modelESP[model], info.label, info.color)
    end

    
    for model, d in pairs(modelESP) do
        if not activeModels[model] then
            hideESPData(d)
            
            if d.hl and d.hl.Parent then d.hl:Destroy(); d.hl=nil end
            
            if not model.Parent then removeESPForModel(model) end
        end
    end
end)


