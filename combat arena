local function matchesBind(inp, bind)
    if not bind then return false end
    if bind.type == "mouse" then return inp.UserInputType == bind.value end
    if bind.type == "key" then
        return inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == bind.value
    end
    return false
end

local function matchesMenuBind(inp, bind)
    if not bind or bind.type ~= "key" then return false end
    if inp.UserInputType ~= Enum.UserInputType.Keyboard then return false end
    if bind.value == Enum.KeyCode.Unknown then return false end
    return inp.KeyCode == bind.value
end

local function getTeam(model)
    
    local plr = Players:GetPlayerFromCharacter(model)
    if plr and plr.Team then return plr.Team.Name end
    
    local tv = model:FindFirstChild("Team")
    if tv and tv.Value then return tv.Value end
    
    local n = model.Name:lower()
    if n:find("red") then return "Red" end
    if n:find("blue") then return "Blue" end
    return nil
end

local function isSameTeamModel(model)
    local myTeam = LocalPlayer.Team and LocalPlayer.Team.Name
    if not myTeam then return false end
    return getTeam(model) == myTeam
end

local function getClosestEnemy(fov)
    local bestModel, bestDist = nil, fov
    local cx = Camera.ViewportSize.X / 2
    local cy = Camera.ViewportSize.Y / 2

    for _, model in ipairs(workspace:GetDescendants()) do
        if not model:IsA("Model") then continue end
        local hum = model:FindFirstChildOfClass("Humanoid")
        if not (hum and hum.Health > 0) then continue end
        if model == LocalPlayer.Character then continue end
        local plr = Players:GetPlayerFromCharacter(model)
        if plr then
            if plr == LocalPlayer then continue end
            if isSameTeamModel(model) then continue end
        end
        local head = model:FindFirstChild("Head")
        if not head then continue end
        local sp, on = Camera:WorldToScreenPoint(head.Position)
        if not on or sp.Z <= 0 then continue end
        local d = math.sqrt((sp.X-cx)^2 + (sp.Y-cy)^2)
        if d < bestDist then bestDist=d; bestModel=model end
    end
    return bestModel
end

local function getClosestHeadWallCheck()
    local bestHead, bestDist = nil, math.huge
    local cx = Camera.ViewportSize.X / 2
    local cy = Camera.ViewportSize.Y / 2

    for _, model in ipairs(workspace:GetDescendants()) do
        if not model:IsA("Model") then continue end
        local hum = model:FindFirstChildOfClass("Humanoid")
        if not (hum and hum.Health > 0) then continue end
        local plr = Players:GetPlayerFromCharacter(model)
        if plr == LocalPlayer then continue end
        if model == LocalPlayer.Character then continue end
        local head = model:FindFirstChild("Head")
        if not head then continue end
        local sp, on = Camera:WorldToScreenPoint(head.Position)
        if not on then continue end
        local d = math.sqrt((sp.X-cx)^2 + (sp.Y-cy)^2)
        if d >= bestDist then continue end
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
        local ray = workspace:Raycast(Camera.CFrame.Position, head.Position - Camera.CFrame.Position, params)
        if ray and ray.Instance:IsDescendantOf(model) then
            bestDist = d
            bestHead = head
        end
    end
    return bestHead
end


