local _infiniteSprint = false
local _sprintConn     = nil
local _isMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled

local function startInfiniteSprint()
    if _sprintConn then return end
    _sprintConn = RunService.Heartbeat:Connect(function()
        if not _infiniteSprint then return end
        local char = LocalPlayer.Character; if not char then return end
        if workspace:FindFirstChild("PLAYERS") and workspace.PLAYERS:FindFirstChild("LOBBY") then
            if char.Parent == workspace.PLAYERS.LOBBY then
                char:SetAttribute("WalkSpeed", 12); return
            end
        end
        if _isMobile then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum and hum.MoveDirection.Magnitude > 0 then
                char:SetAttribute("WalkSpeed", 24)
            else
                char:SetAttribute("WalkSpeed", 12)
            end
        else
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or UserInputService:IsKeyDown(Enum.KeyCode.RightShift) then
                char:SetAttribute("WalkSpeed", 25)
            else
                char:SetAttribute("WalkSpeed", 12)
            end
        end
    end)
end

local function stopInfiniteSprint()
    if _sprintConn then _sprintConn:Disconnect(); _sprintConn=nil end
    local char = LocalPlayer.Character
    if char then char:SetAttribute("WalkSpeed", 12) end
end


