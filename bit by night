local function getPart(char, name)
    if not char then return nil end
    return char:FindFirstChild(name)
        or (name=="Torso" and char:FindFirstChild("UpperTorso"))
        or char:FindFirstChild("Head")
end

local function GetClosestAim(fov, part)
    local closest, best = nil, fov
    local center = Vector2.new(Cam.ViewportSize.X/2, Cam.ViewportSize.Y/2)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local tp = getPart(plr.Character, part)
                if tp then
                    local sp, on = Cam:WorldToViewportPoint(tp.Position)
                    if on then
                        local d = (Vector2.new(sp.X,sp.Y)-center).Magnitude
                        if d < best then closest=plr; best=d end
                    end
                end
            end
        end
    end
    return closest
end

local function isAimBindPressed(inp)
    if not _aimBindObj then return inp.UserInputType==Enum.UserInputType.MouseButton2 end
    local bind = _aimBindObj.Value
    if not bind then return inp.UserInputType==Enum.UserInputType.MouseButton2 end
    if bind.type=="mouse" then return inp.UserInputType==bind.value end
    if bind.type=="key" then
        return inp.UserInputType==Enum.UserInputType.Keyboard and inp.KeyCode==bind.value
    end
    return false
end

RunService.RenderStepped:Connect(function()
    local center = Vector2.new(Cam.ViewportSize.X/2, Cam.ViewportSize.Y/2)
    AimbotCircle.Position = center
    AimbotCircle.Radius   = AimbotSettings.FOV
    AimbotCircle.Color    = AimbotSettings.FOVColor
    
    AimbotCircle.Visible  = AimbotSettings.ShowFOV and AimbotSettings.Enabled and not _hidden

    if not (AimbotSettings.Enabled and _aimState) then AimbotSettings.StickyTarget=nil; return end
    local target
    if AimbotSettings.Sticky and AimbotSettings.StickyTarget then
        local sc  = AimbotSettings.StickyTarget
        local hum = sc.Character and sc.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health>0 then target=sc else AimbotSettings.StickyTarget=nil end
    end
    if not target then
        target = GetClosestAim(AimbotSettings.FOV, AimbotSettings.TargetPart)
        if AimbotSettings.Sticky and target then AimbotSettings.StickyTarget=target end
    end
    if not (target and target.Character) then return end
    local tp = getPart(target.Character, AimbotSettings.TargetPart)
    if tp then Cam.CFrame=Cam.CFrame:Lerp(CFrame.new(Cam.CFrame.Position,tp.Position),AimbotSettings.Smoothness) end
end)

UserInputService.InputBegan:Connect(function(inp, proc)
    if proc or not AimbotSettings.Enabled then return end
    if isAimBindPressed(inp) then
        if _aimMode=="Hold" then _aimState=true
        else _aimState=not _aimState; if not _aimState then AimbotSettings.StickyTarget=nil end end
    end
end)
UserInputService.InputEnded:Connect(function(inp)
    if _aimMode=="Hold" and isAimBindPressed(inp) then
        _aimState=false; AimbotSettings.StickyTarget=nil
    end
end)


