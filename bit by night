workspace.DescendantAdded:Connect(function(o)
    if o:IsA("Model") and o.Name == "Generator" then registerGen(o) end
    if o.Name == "Generators" then
        task.wait(1); for _, c in ipairs(o:GetChildren()) do registerGen(c) end
    end
    if o.Parent and o.Parent.Name == "Generators" then registerGen(o) end
end)
