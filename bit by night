local secUtil = TabMods:AddSection("Utility", "Right")


local _menuBindObj = secUtil:AddMouseKeybind({
    Name="Menu Toggle Key",
    Default={type="key", value=Enum.KeyCode.RightControl},
    Callback=function() end,
})
secUtil:AddLabel({Text="Menu key — keyboard only."})
UserInputService.InputBegan:Connect(function(inp, proc)
    if proc then return end
    if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
    if matchesMenuBind(inp, _menuBindObj.Value) then Window.ToggleWindow() end
end)

secUtil:AddSeparator()


local _hideBindObj = secUtil:AddMouseKeybind({
    Name="Hide Visuals Key",
    Default={type="key", value=Enum.KeyCode.Insert},
    Callback=function() end,
})
secUtil:AddLabel({Text="Hides all ESP and FOV drawings."})

UserInputService.InputBegan:Connect(function(inp, proc)
    if proc then return end
    if not matchesBind(inp, _hideBindObj.Value) then return end
    _hidden = not _hidden
    
    if _hidden then
        AimbotCircle.Visible = false
        for _, esp in pairs(ESP_Cache) do hideAllESPDrawings(esp) end
        for _, e in pairs(Gen_Cache)     do e.Text.Visible=false end
        for _, e in pairs(Battery_Cache) do e.Text.Visible=false end
    end
    
end)

secUtil:AddSeparator()


secUtil:AddButton({Name="Rejoin Server", Callback=function()
    local lp = Players.LocalPlayer
    if game.JobId ~= "" then TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, lp)
    else TeleportService:Teleport(game.PlaceId, lp) end
end})

secUtil:AddSeparator()


local _unloadBindObj = secUtil:AddMouseKeybind({
    Name="Unload Key",
    Default={type="key", value=Enum.KeyCode.End},
    Callback=function() end,
})
secUtil:AddLabel({Text="Press to fully unload the script."})


local function fullUnload()
    
    AimbotSettings.Enabled=false; _aimState=false; AimbotSettings.StickyTarget=nil
    AimbotCircle.Visible=false

    
    Config.InfStamina=false


    toggleFullbright(false)

    
    Config.AntiStun=false

    
    Config.KillerAlert=false

    
    _jumpBoost=false
    if _jpLoop then _jpLoop:Disconnect(); _jpLoop=nil end
    if _jpCA   then _jpCA:Disconnect();   _jpCA=nil   end
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            if hum.UseJumpPower then hum.JumpPower=0 else hum.JumpHeight=0 end
        end
    end

    
    _noclipEnabled=false
    if _noclipConn then _noclipConn:Disconnect(); _noclipConn=nil end
    if char then
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide=true end
        end
    end

    
    _infiniteSprint=false; stopInfiniteSprint()

    
    _tpEnabled=false; _tpHolding=false

    
    _hidden=false

    
    Config.ESP=false; Config.GenESP=false; Config.BatteryESP=false
    for _, esp in pairs(ESP_Cache) do
        for _, o in pairs(esp) do pcall(function() o:Remove() end) end
    end
    ESP_Cache={}
    for _, e in pairs(Gen_Cache)     do pcall(function() e.Text:Remove() end) end
    Gen_Cache={}
    for _, e in pairs(Battery_Cache) do pcall(function() e.Text:Remove() end) end
    Battery_Cache={}

    
    task.wait(0.1)
    if Window._ScreenGui and Window._ScreenGui.Parent then
        pcall(function() Window._ScreenGui:Destroy() end)
    end
end

UserInputService.InputBegan:Connect(function(inp, proc)
    if proc then return end
    if matchesBind(inp, _unloadBindObj.Value) then fullUnload() end
end)
